{
  "name": "my-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "node --test electron/services/config.test.js electron/services/presets.test.js electron/services/mods.test.js electron/services/gamebanana.test.js electron/services/ipc.test.js electron/services/logger.test.js",
    "preview": "vite preview",
    "electron:start": "cross-env NODE_ENV=development electron .",
